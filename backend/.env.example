# =========================================================================
# School Management System Configuration
# =========================================================================

# Database Connection (Leave empty to default to local MySQL root@localhost:3306)
# For Supabase, paste your connection string (URI) from:
# Settings -> Database -> Connection string -> URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Flask Configuration
FLASK_SECRET=your-flask-secret-key-here

# JWT Authentication Config
JWT_SECRET=your-jwt-auth-secret-key-here
